# AI Intelligence OS — Production Environment
# Copy to .env and adjust ALL values before deployment.

# Application
APP_ENV=production
APP_PORT=8000
APP_DEBUG=false

# Database — use internal Docker network hostname, strong password
DATABASE_URL=postgresql://app_user:${DB_PASSWORD}@postgres:5432/ai_intelligence_os
POSTGRES_USER=app_user
POSTGRES_PASSWORD=__CHANGE_ME_STRONG_PASSWORD__
POSTGRES_DB=ai_intelligence_os
POSTGRES_PORT=5432
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20

# Redis — require authentication
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
REDIS_PASSWORD=__CHANGE_ME_STRONG_PASSWORD__
REDIS_PORT=6379

# Qdrant — enable API key auth
QDRANT_URL=http://qdrant:6333
QDRANT_PREFER_GRPC=true
QDRANT_PORT=6333
QDRANT_HTTP_PORT=6334
QDRANT_API_KEY=__CHANGE_ME__

# MinIO — use strong credentials
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=intelligence
MINIO_ACCESS_KEY=__CHANGE_ME__
MINIO_SECRET_KEY=__CHANGE_ME__
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# LiteLLM
LITELLM_GATEWAY_URL=http://litellm:4000
LITELLM_API_KEY=__CHANGE_ME__

# Frontend
NEXT_PUBLIC_API_URL=http://backend:8000
FRONTEND_PORT=3000

# Monitoring
OTEL_SERVICE_NAME=ai-intelligence-os-prod
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
