{
  "$schema": "https://stylelint.com/schema",
  "extends": ["stylelint-config-standard"],
  "rules": {
    "custom-property-empty-line-before": false,
    "declaration-empty-line-before": false,
    "at-rule-no-unknown": [
      true,
      { "ignoreAtRules": ["tailwind", "apply", "variants", "responsive", "screen", "layer", "theme"] }
    ]
  }
}
