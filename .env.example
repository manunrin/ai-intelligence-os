# =============================================================================
# AI Intelligence OS — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# All variables used by docker-compose.yml and application services.
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
# Runtime environment: development | staging | production
APP_ENV=development

# Backend HTTP port (container-internal)
APP_PORT=8000

# Enable debug mode (more verbose logging, stack traces)
APP_DEBUG=true

# ---------------------------------------------------------------------------
# PostgreSQL — Relational Database
# ---------------------------------------------------------------------------
# Connection URL used by backend (docker service name: postgres)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/ai_intelligence_os

# PostgreSQL superuser credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_intelligence_os

# Port mapping on host machine
POSTGRES_PORT=5432

# SQLAlchemy connection pool size
DATABASE_POOL_MIN=1
DATABASE_POOL_MAX=10

# ---------------------------------------------------------------------------
# Redis — Cache & Message Broker
# ---------------------------------------------------------------------------
# Connection URL used by backend (docker service name: redis)
REDIS_URL=redis://redis:6379/0

# Redis authentication password
REDIS_PASSWORD=redispassword

# Port mapping on host machine
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# Qdrant — Vector Database
# ---------------------------------------------------------------------------
# gRPC endpoint used by backend (docker service name: qdrant)
QDRANT_URL=http://qdrant:6333

# Prefer gRPC over HTTP API
QDRANT_PREFER_GRPC=true

# Port mappings on host machine
QDRANT_PORT=6333
QDRANT_HTTP_PORT=6334

# Optional API key for authenticated access (leave empty to disable)
QDRANT_API_KEY=

# ---------------------------------------------------------------------------
# MinIO — Object Storage
# ---------------------------------------------------------------------------
# API endpoint used by backend (docker service name: minio)
MINIO_ENDPOINT=minio:9000

# Default bucket for documents, images, HTML content
MINIO_BUCKET=intelligence

# Port mappings on host machine
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ---------------------------------------------------------------------------
# LiteLLM Gateway — Unified LLM Provider Interface
# ---------------------------------------------------------------------------
# Gateway URL (not included in default compose; add service when needed)
LITELLM_GATEWAY_URL=http://litellm:4000
LITELLM_API_KEY=sk-litellm-key

# ---------------------------------------------------------------------------
# Frontend — Next.js Application
# ---------------------------------------------------------------------------
# Backend API base URL (for browser → container communication)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Port mapping on host machine
FRONTEND_PORT=3000

# ---------------------------------------------------------------------------
# Monitoring — OpenTelemetry
# ---------------------------------------------------------------------------
# Service name for trace identification
OTEL_SERVICE_NAME=ai-intelligence-os

# OTLP exporter endpoint (collector URL)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ---------------------------------------------------------------------------
# MCP — Model Context Protocol Infrastructure
# ---------------------------------------------------------------------------
# Enable or disable the entire MCP layer
MCP_ENABLED=true

# Notion integration
NOTION_TOKEN=
NOTION_DATABASE_ID=

# Asana integration
ASANA_TOKEN=
ASANA_WORKSPACE_ID=
ASANA_PROJECT_ID=

# GitHub integration
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPOSITORY=

# Browser integration
BROWSER_API_URL=
BROWSER_API_KEY=
