# Application
APP_ENV=development
APP_PORT=8000
APP_DEBUG=true

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_intelligence_os
DATABASE_POOL_MIN=1
DATABASE_POOL_MAX=10

# Redis
REDIS_URL=redis://localhost:6379/0

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_PREFER_GRPC=true

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=intelligence

# LiteLLM
LITELLM_GATEWAY_URL=http://localhost:4000
LITELLM_API_KEY=sk-litellm-key

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Monitoring
OTEL_SERVICE_NAME=ai-intelligence-os
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
