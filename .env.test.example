# AI Intelligence OS — Test Environment
# Copy to .env and adjust values. Isolated data per test run.

# Application
APP_ENV=test
APP_PORT=8000
APP_DEBUG=true

# Database — isolated test database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/ai_intelligence_os_test
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_intelligence_os_test
POSTGRES_PORT=5433
DATABASE_POOL_MIN=1
DATABASE_POOL_MAX=5

# Redis — isolated test DB index
REDIS_URL=redis://redis:6379/1
REDIS_PASSWORD=redispassword
REDIS_PORT=6380

# Qdrant — isolated test collection prefix
QDRANT_URL=http://qdrant:6333
QDRANT_PREFER_GRPC=true
QDRANT_PORT=6333
QDRANT_HTTP_PORT=6334
QDRANT_API_KEY=

# MinIO — isolated test bucket
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=ai_intelligence_os_test
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# LiteLLM — use mock/local models for tests
LITELLM_GATEWAY_URL=http://litellm:4000
LITELLM_API_KEY=sk-test-key

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_PORT=3000

# Monitoring — disabled for tests
OTEL_SERVICE_NAME=ai-intelligence-os-test
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
