# AI Intelligence OS — Development Environment
# Copy to .env and adjust values.

# Application
APP_ENV=development
APP_PORT=8000
APP_DEBUG=true

# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/ai_intelligence_os
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_intelligence_os
POSTGRES_PORT=5432
DATABASE_POOL_MIN=1
DATABASE_POOL_MAX=10

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=redispassword
REDIS_PORT=6379

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_PREFER_GRPC=true
QDRANT_PORT=6333
QDRANT_HTTP_PORT=6334
QDRANT_API_KEY=

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=intelligence
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# LiteLLM
LITELLM_GATEWAY_URL=http://litellm:4000
LITELLM_API_KEY=sk-litellm-key

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_PORT=3000

# Monitoring
OTEL_SERVICE_NAME=ai-intelligence-os
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
